# SimplePool 配置示例
# 仅供本地开发演示，生产环境必须替换管理员密码与主密钥。

SIMPLEPOOL_HTTP_ADDR=127.0.0.1:7891
SIMPLEPOOL_LOG_LEVEL=info

SIMPLEPOOL_DATA_DIR=.simplepool/data
SIMPLEPOOL_RUNTIME_DIR=.simplepool/runtime
SIMPLEPOOL_TEMP_DIR=.simplepool/tmp
# SIMPLEPOOL_DB_PATH=.simplepool/data/simplepool.db

SIMPLEPOOL_ADMIN_USERNAME=admin
SIMPLEPOOL_ADMIN_PASSWORD=change-me

# 32 字节主密钥的 Base64 编码示例。生产环境请替换为你自己的密钥。
SIMPLEPOOL_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# 如果你更想把主密钥放到文件里，可改用下面这行，并删除上面的 SIMPLEPOOL_MASTER_KEY。
# SIMPLEPOOL_MASTER_KEY_FILE=.simplepool/master.key
